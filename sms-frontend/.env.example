# Copy to .env.local for overrides (optional).
#
# Local development (npm run dev):
#   Leave empty — Vite proxies /api to http://localhost:8080
#   VITE_API_BASE_URL=
#
# Production build (npm run build):
#   Set your deployed API origin (no trailing slash)
#   VITE_API_BASE_URL=https://your-api.example.com

VITE_API_BASE_URL=
