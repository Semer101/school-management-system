DATABASE_URL=postgres://user:pass@localhost:5432/sms?sslmode=disable
JWT_SECRET=your-long-secret
ENV=development
PORT=8080

# SMTP — required for password-reset OTP emails (Forgot Password)
# If SMTP_HOST is empty, OTP is only printed to the server console (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@sms.et

# Frontend URL for CORS (production)
FRONTEND_URL=http://localhost:5180
